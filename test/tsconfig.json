{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitThis": false,
    "downlevelIteration": true,
    "skipLibCheck": true
  },
  "include": [
    "./**/*.ts"
  ]
}
